[Unit]
Description=E-services Tirage (Flask + Gunicorn)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/tirage-concours/backend
Environment="PATH=/var/www/tirage-concours/venv/bin"
Environment="PRODUCTION=1"
ExecStart=/var/www/tirage-concours/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8000 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
